{
  "name": "class-feedback",
  "version": "0.1.0",
  "private": true,
  "description": "Class feedback and Q&A platform",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:migrate": "pnpm -F database prisma migrate deploy",
    "db:migrate:dev": "pnpm -F database prisma migrate dev",
    "db:push": "pnpm -F database prisma db push",
    "db:studio": "pnpm -F database prisma studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "turbo": "^2.0.11",
    "typescript": "^5.4.5"
  }
}
