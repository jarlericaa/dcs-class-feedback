{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    },
    "project": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ]
  },
  "ignorePatterns": [
    "dist",
    ".next",
    "coverage",
    "node_modules",
    "*.config.js",
    "*.config.ts",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "overrides": [
    {
      "files": ["*.config.ts", "*.config.js", "**/*.test.ts", "**/*.test.tsx"],
      "parserOptions": {
        "project": null
      }
    }
  ]
}
