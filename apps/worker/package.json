{
  "name": "@class-feedback/worker",
  "version": "0.1.0",
  "description": "Background job worker",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@class-feedback/config": "workspace:*",
    "@class-feedback/database": "workspace:*",
    "@class-feedback/email": "workspace:*",
    "pg-boss": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^1.2.0"
  }
}
