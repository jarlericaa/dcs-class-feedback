generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  googleId      String    @unique
  displayName   String
  picture       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  platformRole      PlatformRole?
  courseMemberships CourseMembership[]
  auditEvents       AuditEvent[]

  @@index([email])
  @@index([googleId])
}

model PlatformRole {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("instructor")
  grantedAt DateTime @default(now())

  @@index([userId])
}

model Course {
  id              String    @id @default(cuid())
  title           String
  code            String
  semester        String
  year            Int
  timezone        String    @default("UTC")
  isArchived      Boolean   @default(false)
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships         CourseMembership[]
  rosterEntries       RosterEntry[]
  templates           FeedbackTemplate[]
  schedules           RecurrenceSchedule[]
  formInstances       FormInstance[]
  bonusPeriods        BonusPeriod[]
  privateThreads      PrivateThread[]
  publicQAEntries     PublicQAEntry[]
  auditEvents         AuditEvent[]

  @@unique([code, semester, year])
  @@index([isArchived])
}

model CourseMembership {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  role      String   // "instructor", "student_assistant", "student"
  joinedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([role])
}

model RosterEntry {
  id              String    @id @default(cuid())
  courseId        String
  studentNumber   String
  familyName      String
  firstName       String
  livedName       String?
  preferredPronoun String?
  program         String?
  enrollmentStatus String
  enlistedDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  accountClaim  AccountClaim?
  submissions   Submission[]
  questions     StudentQuestion[]
  privateThreads PrivateThread[]

  @@unique([courseId, studentNumber])
  @@index([courseId])
  @@index([studentNumber])
}

model AccountClaim {
  id            String    @id @default(cuid())
  rosterEntryId String    @unique
  userId        String
  status        String    @default("pending") // "pending", "linked", "rejected"
  linkedAt      DateTime?
  reason        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rosterEntry RosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)

  @@index([rosterEntryId])
  @@index([userId])
  @@index([status])
}

model FeedbackTemplate {
  id          String    @id @default(cuid())
  courseId    String
  title       String
  description String?
  schema      Json      // Form schema with field definitions
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course    Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  schedules RecurrenceSchedule[]
  instances FormInstance[]

  @@index([courseId])
  @@index([isArchived])
}

model RecurrenceSchedule {
  id              String    @id @default(cuid())
  templateId      String
  courseId        String
  title           String
  description     String?
  schedule        String    // Cron expression
  releaseTime     DateTime
  deadline        DateTime
  bonusPeriodId   String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  template    FeedbackTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  bonusPeriod BonusPeriod?     @relation(fields: [bonusPeriodId], references: [id])
  instances   FormInstance[]

  @@index([templateId])
  @@index([courseId])
  @@index([isActive])
}

model FormInstance {
  id              String    @id @default(cuid())
  courseId        String
  templateId      String
  scheduleId      String?
  title           String
  schema          Json      // Snapshot of template schema
  releaseTime     DateTime
  deadline        DateTime
  bonusPeriodId   String
  status          String    @default("scheduled") // "scheduled", "open", "closed", "archived"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template     FeedbackTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  schedule     RecurrenceSchedule? @relation(fields: [scheduleId], references: [id])
  bonusPeriod  BonusPeriod       @relation(fields: [bonusPeriodId], references: [id])
  prompts      FormPrompt[]
  submissions  Submission[]
  questions    StudentQuestion[]

  @@unique([courseId, templateId, releaseTime])
  @@index([courseId])
  @@index([status])
  @@index([deadline])
}

model FormPrompt {
  id        String    @id @default(cuid())
  formId    String
  order     Int
  type      String    // "text", "textarea", "multiple_choice", "checkbox", "rating", "question"
  label     String
  required  Boolean   @default(false)
  schema    Json?     // Additional schema for the field
  createdAt DateTime  @default(now())

  form      FormInstance     @relation(fields: [formId], references: [id], onDelete: Cascade)
  responses PromptResponse[]

  @@index([formId])
  @@index([order])
}

model Submission {
  id              String    @id @default(cuid())
  formId          String
  rosterEntryId   String
  status          String    @default("draft") // "draft", "submitted", "locked"
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  form            FormInstance      @relation(fields: [formId], references: [id], onDelete: Cascade)
  rosterEntry     RosterEntry       @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  promptResponses PromptResponse[]
  questions       StudentQuestion[]
  validity        SubmissionValidity?

  @@unique([formId, rosterEntryId])
  @@index([formId])
  @@index([rosterEntryId])
  @@index([status])
}

model PromptResponse {
  id        String    @id @default(cuid())
  submissionId String
  promptId  String
  value     Json      // The actual response (can be text, number, array, etc.)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  prompt     FormPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([submissionId, promptId])
  @@index([submissionId])
  @@index([promptId])
}

model StudentQuestion {
  id              String    @id @default(cuid())
  formId          String
  submissionId    String
  rosterEntryId   String
  question        String    // Original student question
  internalStatus  String    @default("pending") // "pending", "answered", "will_not_answer"
  studentVisibleStatus String @default("received") // "received", "answered_privately", "answered_publicly"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  form              FormInstance      @relation(fields: [formId], references: [id], onDelete: Cascade)
  submission        Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  rosterEntry       RosterEntry       @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  backlogItem       BacklogItem?
  privateThreads    PrivateThread[]
  questionLinks     QuestionLink[]    @relation("original")
  linkedToItems     QuestionLink[]    @relation("linked")

  @@index([formId])
  @@index([submissionId])
  @@index([rosterEntryId])
  @@index([internalStatus])
  @@index([studentVisibleStatus])
}

model BonusPeriod {
  id            String    @id @default(cuid())
  courseId      String
  title         String
  requiredCount Int
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  course            Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  formInstances     FormInstance[]
  schedules         RecurrenceSchedule[]

  @@unique([courseId, title])
  @@index([courseId])
}

model SubmissionValidity {
  id            String    @id @default(cuid())
  submissionId  String    @unique
  status        String    @default("valid") // "valid", "flagged", "invalid"
  reason        String?
  flaggedBy     String?
  confirmedBy   String?
  flaggedAt     DateTime?
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([status])
}

model BacklogItem {
  id              String    @id @default(cuid())
  courseId        String
  questionId      String    @unique
  topic           String?
  priority        Int       @default(0)
  assignedTo      String?
  targetDate      DateTime?
  status          String    @default("recommended") // "recommended", "confirmed", "assigned", "drafting", "awaiting_approval", "answered"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  question        StudentQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  publicQAEntry   PublicQAEntry?

  @@index([courseId])
  @@index([status])
  @@index([assignedTo])
}

model QuestionLink {
  id              String    @id @default(cuid())
  originalId      String
  linkedId        String
  publicQAEntryId String?
  createdAt       DateTime  @default(now())

  original        StudentQuestion @relation("original", fields: [originalId], references: [id], onDelete: Cascade)
  linked          StudentQuestion @relation("linked", fields: [linkedId], references: [id], onDelete: Cascade)
  publicQAEntry   PublicQAEntry?  @relation(fields: [publicQAEntryId], references: [id])

  @@unique([originalId, linkedId])
  @@index([originalId])
  @@index([linkedId])
  @@index([publicQAEntryId])
}

model PrivateThread {
  id              String    @id @default(cuid())
  courseId        String
  questionId      String
  rosterEntryId   String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  question        StudentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rosterEntry     RosterEntry     @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  messages        PrivateMessage[]

  @@unique([questionId])
  @@index([courseId])
  @@index([rosterEntryId])
}

model PrivateMessage {
  id          String    @id @default(cuid())
  threadId    String
  senderEmail String    // Store email for audit
  content     String
  createdAt   DateTime  @default(now())

  thread PrivateThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model PublicQAEntry {
  id              String    @id @default(cuid())
  courseId        String
  backlogItemId   String    @unique
  displayedQuestion String
  answer          String
  topic           String?
  status          String    @default("draft") // "draft", "awaiting_approval", "published", "unpublished"
  publishedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  course          Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  backlogItem     BacklogItem         @relation(fields: [backlogItemId], references: [id], onDelete: Cascade)
  questionLinks   QuestionLink[]
  revisions       PublicQARevision[]

  @@index([courseId])
  @@index([status])
  @@index([topic])
}

model PublicQARevision {
  id          String    @id @default(cuid())
  entryId     String
  displayedQuestion String
  answer      String
  changedAt   DateTime  @default(now())

  entry PublicQAEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model AuditEvent {
  id        String    @id @default(cuid())
  userId    String
  courseId  String?
  action    String
  entityType String
  entityId  String
  changes   Json?
  reason    String?
  createdAt DateTime  @default(now())

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([action])
  @@index([createdAt])
}

model EmailEvent {
  id          String    @id @default(cuid())
  recipientEmail String
  eventType   String    // "form_opened", "deadline_reminder", "private_answer", "public_answer", "submission_invalidated"
  entityType  String?
  entityId    String?
  status      String    @default("pending") // "pending", "sent", "failed"
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
}
